# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── WhatsApp Provider ─────────────────────────────────────────────────────────
# Choose one: "twilio" | "meta"
WHATSAPP_PROVIDER=twilio

# ── Option A: Twilio WhatsApp ─────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Your Twilio WhatsApp-enabled number (no "whatsapp:" prefix here)
TWILIO_WHATSAPP_FROM=+14155238886

# Twilio Content Template SIDs (from Twilio Console → Messaging → Content)
# These are the pre-approved template Content SIDs
TWILIO_TEMPLATE_SID_CONFIRMATION=HXxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_SID_REMINDER=HXxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_SID_PROMOTION=HXxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Option B: Meta Cloud API ──────────────────────────────────────────────────
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_permanent_system_user_token
# (template names are hardcoded: booking_confirmation, appointment_reminder, promotional_offer)
